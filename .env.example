# Copy to .env — NEVER commit .env to GitHub

DATABASE_URL=sqlite:///./securerag.db
# Production (Railway sets this automatically when you add PostgreSQL):
# DATABASE_URL=postgresql://user:pass@host:5432/securerag

APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO

API_KEYS=sk-dev-key-1234,sk-dev-key-5678
API_KEY_HEADER=X-API-Key

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

BLOCK_THRESHOLD=40
CORS_ORIGINS=*


# ── Paddle Billing (global payments — works from Israel) ──────────────────────
# Sign up at paddle.com, create products for each plan, then fill these in.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox

# Create prices in Paddle dashboard and paste the price IDs (pri_...) here:
PADDLE_PRICE_STARTER=
PADDLE_PRICE_GROWTH=
PADDLE_PRICE_ENTERPRISE=

PADDLE_SUCCESS_URL=https://your-app.railway.app/payment/success
PADDLE_CANCEL_URL=https://your-app.railway.app/payment/cancel

# ── Tranzilla (Israeli clients only — ILS payments) ────────────────────────────
# Tranzilla (https://www.tranzila.com/en/developers):
TRANZILLA_SUPPLIER=
TRANZILLA_TOKEN=
TRANZILLA_NOTIFY_URL=https://your-app.railway.app/billing/payment/webhook
TRANZILLA_SUCCESS_URL=https://your-app.railway.app/payment/success
TRANZILLA_FAIL_URL=https://your-app.railway.app/payment/fail

MODEL_PATH=./models/injection_classifier.joblib
ML_MALICIOUS_THRESHOLD=0.65
